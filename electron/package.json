{
  "name": "lee",
  "productName": "Lee",
  "version": "0.1.0",
  "description": "Terminal IDE with AI assistance - The Meta-IDE",
  "main": "dist/main/main.js",
  "author": "Coefficiency",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "fetch-python": "bash scripts/download-python.sh",
    "dist": "npm run fetch-python && electron-builder",
    "dist:mac": "npm run fetch-python && electron-builder --mac",
    "dist:win": "npm run fetch-python && electron-builder --win",
    "dist:linux": "npm run fetch-python && electron-builder --linux",
    "clean": "rm -rf dist out node_modules/.vite",
    "typecheck": "tsc --noEmit",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "npx @electron/rebuild"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.7.0",
    "@codemirror/lang-cpp": "^6.0.2",
    "@codemirror/lang-css": "^6.3.0",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-java": "^6.0.1",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/lang-python": "^6.1.6",
    "@codemirror/lang-rust": "^6.0.1",
    "@codemirror/lang-sql": "^6.8.0",
    "@codemirror/lang-yaml": "^6.1.1",
    "@codemirror/language": "^6.10.3",
    "@codemirror/search": "^6.5.6",
    "@codemirror/state": "^6.4.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.34.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "express": "^4.18.2",
    "js-yaml": "^4.1.1",
    "mermaid": "^11.12.2",
    "node-pty": "^0.10.1",
    "react-markdown": "^9.0.1",
    "react-resizable-panels": "^4.2.0",
    "remark-gfm": "^4.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^26.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vite-plugin-electron": "^0.28.0"
  },
  "build": {
    "appId": "net.coefficiency.lee",
    "productName": "Lee",
    "directories": {
      "output": "out",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "lee.config.json"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "hester-src",
        "filter": [
          "pyproject.toml",
          "README.md",
          "hester/**/*.py",
          "hester/**/*.yaml",
          "hester/**/*.json",
          "!hester/**/__pycache__/**"
        ]
      },
      {
        "from": "resources/python-standalone",
        "to": "python",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "resources/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "resources/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  }
}
