# Hester Slack Bot Configuration
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git

# Slack Credentials (regenerate if exposed!)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Optional: Slack workspace config
SLACK_WORKSPACE_ID=T09CAK2D6AH
SLACK_BRIEF_CHANNEL=#daily-brief
SLACK_DEV_CHANNEL=#dev

# Google API (for Gemini)
GOOGLE_API_KEY=your-google-api-key

# GitHub (for brief sources)
GITHUB_TOKEN=your-github-token
GITHUB_ORG=coefficiencynetwork

# Linear (optional, for brief sources)
LINEAR_API_KEY=your-linear-api-key

# Database (uses local Supabase by default)
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=your-local-anon-key
